# ── Qdrant Cloud ──────────────────────────────────────────
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_CLUSTER_URL=your_qdrant_cluster_url_here

# ── LLMs & Embeddings ─────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
VOYAGE_API_KEY=your_voyage_api_key_here

# ── FastAPI backend ───────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── App config ────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Academic Research Assistant

# ══════════════════════════════════════════════════════════
# RAG HYPERPARAMETERS — Change these to run experiments
# ══════════════════════════════════════════════════════════

# Chunking — affects what gets stored in Qdrant on next upload
# Options: 300 | 500 | 700 | 1000
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval — affects every /api/chat call immediately on restart
# Options: dense | hybrid | hybrid_rerank
RETRIEVAL_MODE=dense

# How many chunks to pass to the LLM as context
# Options: 3 | 5 | 6 | 10 | 20
TOP_K=6

# For hybrid_rerank: how many candidates to retrieve before reranking
# Must be >= TOP_K. Typical: 20-50
RERANK_TOP_N=50

# LLM config
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.3

# Qdrant collection name
COLLECTION_NAME=academic_rag_demo

# ══════════════════════════════════════════════════════════
# EVALUATION MODE — Set to true to log every query to CSV
# ══════════════════════════════════════════════════════════
# When true: writes evaluation/{mode}_log.csv for every chat request
# Run: python metrics.py --golden golden_dataset.json --k 6
EVALUATION_MODE=false

# BM25 corpus limit (max chunks to scroll for hybrid retrieval)
BM25_CORPUS_LIMIT=2000

# Ingestion batching (Voyage AI free tier: 3 RPM, 10k TPM)
INGEST_BATCH_SIZE=15
INGEST_BATCH_SLEEP_S=21
